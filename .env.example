# =============================================================================
# KazmaAI - Environment Configuration / إعدادات البيئة
# =============================================================================
# Copy this file to .env and fill in your secrets
# انسخ هذا الملف إلى .env واملأ مفاتيحك السرية
#
# NEVER commit .env to git - it's in .gitignore
# لا تضع .env أبداً في git - هو في .gitignore
# =============================================================================

# -------------------------------------------------------------------------
# API Keys / مفاتيح API
# -------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGINGFACE_API_KEY=hf_...
OPENROUTER_API_KEY=sk-or-...
NVIDIA_API_KEY=nvapi-...

# GitHub (for agent's own repo management if needed)
# جيت هب (لإدارة مستودعات الوكيل إذا لزم)
GITHUB_TOKEN=ghp_...

# -------------------------------------------------------------------------
# Telegram Bot (Phase 2) / بوت تليجرام (المرحلة 2)
# -------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_HOME_CHAT_ID=-1001234567890

# -------------------------------------------------------------------------
# Web Interface (Phase 2) / واجهة الويب (المرحلة 2)
# -------------------------------------------------------------------------
WEB_ADMIN_USER=admin
WEB_ADMIN_PASS=changeme

# -------------------------------------------------------------------------
# Local Services / الخدمات المحلية
# -------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
LMSTUDIO_MODELS_PATH=/path/to/lmstudio/models
LOCAL_API_URL=http://localhost:1234/v1
COMFYUI_URL=http://127.0.0.1:8188

# -------------------------------------------------------------------------
# Agent Security / أمان الوكيل
# -------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ولّده بـ: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_SECRET_KEY=

# -------------------------------------------------------------------------
# Arabic Localization / الترجمة العربية
# -------------------------------------------------------------------------
# Primary language for agent responses (ar=Arabic, en=English)
# اللغة الافتراضية لاستجابات الوكيل (ar=العربية, en=English)
AGENT_LANGUAGE=ar

# Fallback language if Arabic model unavailable
# اللغة الاحتياطية إذا لم يكن النموذج العربي متاحاً
AGENT_LANGUAGE_FALLBACK=en